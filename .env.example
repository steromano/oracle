# Oracle secrets — copy to .env and fill in. Never commit .env.
# Connectors degrade gracefully when a key is absent.

# FRED (economic data series)
#FRED_API_KEY=

# Metaculus (required for the Metaculus connector — reads now need a token)
#METACULUS_API_TOKEN=

# AskNews (optional news connector)
#ASKNEWS_CLIENT_ID=
#ASKNEWS_CLIENT_SECRET=

# OpenRouter (optional secondary model pool)
#OPENROUTER_API_KEY=

# Webhook for cron notifications
#ORACLE_WEBHOOK_URL=
